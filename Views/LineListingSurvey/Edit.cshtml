        async function updateSurvey() {
            // Helper: safely parse int or return null
            const getInt = (id) => {
                const el = document.getElementById(id);
                if (!el) return null;
                const val = el.value;
                const parsed = parseInt(val);
                return isNaN(parsed) ? null : parsed;
            };

            // Required: LineListId must exist
            const lineListId = getInt("LineListId");
            if (!lineListId) {
                alert("Error: LineListId missing! Cannot update.");
                return;
            }

            // Optional: other required fields for form validation
            const requiredFields = [
                { id: "StateId", name: "State" },
                { id: "DistrictId", name: "District" },
                { id: "BlockId", name: "Block" },
                { id: "FacilityId", name: "Facility" },
                { id: "SubCenterId", name: "Sub-Centre" },
                { id: "ASHAId", name: "ASHA" },
                { id: "WomanName", name: "Woman Name" }
            ];

            for (const f of requiredFields) {
                const val = document.getElementById(f.id)?.value;
                if (!val) {
                    alert(`Error: ${f.name} is required.`);
                    return;
                }
            }

            // Build payload with nullable handling
            const model = {
                lineListId: lineListId,
                lineListGuid: document.getElementById("LineListGuid")?.value || null,
                stateId: getInt("StateId"),
                districtId: getInt("DistrictId"),
                blockId: getInt("BlockId"),
                facilityId: getInt("FacilityId"),
                subCenterId: getInt("SubCenterId"),
                ashaId: getInt("ASHAId"),
                villageName: document.getElementById("VillageName")?.value || null,
                anganwadiWorkerName: document.getElementById("AnganwadiWorkerName")?.value || null,
                womanName: document.getElementById("WomanName")?.value || null,
                husbandName: document.getElementById("HusbandName")?.value || null,
                mobileNumber: document.getElementById("MobileNumber")?.value || null,
                marriageMonth: getInt("MarriageMonth"),
                marriageYear: getInt("MarriageYear"),
                isChildAvailable: getInt("IsChildAvailable"),
                childGender: getInt("ChildGender"),
                childDOB: document.getElementById("ChildDOB")?.value || null,
                childAge: getInt("ChildAge"),
                isCurrentlyPregnant: getInt("IsCurrentlyPregnant"),
                isUsingFamilyPlanning: getInt("IsUsingFamilyPlanning"),
                familyPlanningMethod: document.getElementById("FamilyPlanningMethod")?.value || null,
                isAwareOfAntara: getInt("IsAwareOfAntara"),
                selectedMethodName: document.getElementById("SelectedMethodName")?.value || null,
                reasonForNonUsage: document.getElementById("ReasonForNonUsage")?.value || null,
                isConcent: getInt("IsConcent"),
                concentDate: document.getElementById("ConcentDate")?.value || null,
                signature: document.getElementById("Signature")?.value || null
            };

            console.log("Payload to send:", model);

            try {
                const response = await fetch('/LineListingSurvey/Edit', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json',
                        'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                    },
                    body: JSON.stringify(model)
                });

                if (!response.ok) {
                    alert("HTTP Error: " + response.status);
                    return;
                }

                const res = await response.json();
                console.log("Response from server:", res);

                if (res.success) {
                    alert("Updated successfully!");
                    window.location.href = '@Url.Action("Index", "LineListingSurvey")';
                } else {
                    alert("Update failed: " + res.message);
                }
            } catch (err) {
                console.error("Update failed:", err);
                alert("Unexpected error occurred. Check console for details.");
            }
        }
    </script>

