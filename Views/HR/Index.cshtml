<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<script>
    let selectedFacilityId = 0;
    let selectedHrId = 0;
    let currentPage = 1;
    const pageSize = 10;

    $(document).ready(function () {
        loadHrList(currentPage);
    });

    // Add HR
    $(document).on("click", ".addhrstatus", function () {
        selectedFacilityId = $(this).data("facility-id");
        selectedHrId = 0;

        clearHrModal();
        $("#HrId").val(0);
        $("#FacilityId").val(selectedFacilityId);
        $("#hrStatusModal").modal("show");
    });

    // Edit HR
    $(document).on("click", ".editHr", function () {
        selectedHrId = $(this).data("id");

        $.get('/HR/GetHrStatus', { hrId: selectedHrId }, function (data) {
            clearHrModal();

            $("#HrId").val(data.hrId || 0);
            $("#FacilityId").val(data.facilityId || 0);
            $("#Name").val(data.name || "");
            $("#Mobile").val(data.mobile || "");
            $("#DesignationId").val(data.designationId ?? "");
            $("#GenderId").val(data.genderId ?? "");
            $("#Status").val(data.status ?? "");
            $("#TrainedAntaraGovt").val(data.trainedAntaraGovt ?? "");
            $("#TrainedAntaraIDF").val(data.trainedAntaraIDF ?? "");
            $("#AttendentVCAT").val(data.attendentVCAT ?? "");
            $("#TrainedInIUCD").val(data.trainedInIUCD ?? "");
            $("#TrainedInFPLMIS").val(data.trainedInFPLMIS ?? "");
            $("#TrainedInCACS_MMA").val(data.trainedInCACS_MMA ?? "");
    $("#hrModalTitle").text("Edit HR Profile");
              $("#btnSaveHr").text("Update");
              handleStatusChange();
              $("#hrStatusModal").modal("show");

        }).fail(function () {
            Swal.fire('Error', 'Unable to fetch HR details', 'error');
        });
    });

    // Save / Update HR
    $(document).on("click", "#btnSaveHr", function () {
        let modelhr = {
            HrId: parseInt($("#HrId").val() || "0"),
            FacilityId: parseInt($("#FacilityId").val() || "0"),
            Name: $("#Name").val(),
            Mobile: $("#Mobile").val(),
            DesignationId: parseInt($("#DesignationId").val() || "0"),
            GenderId: parseInt($("#GenderId").val() || "0"),
            Status: $("#Status").val(),
            TrainedAntaraGovt: $("#TrainedAntaraGovt").val() || null,
            TrainedAntaraIDF: $("#TrainedAntaraIDF").val() || null,
            AttendentVCAT: $("#AttendentVCAT").val() || null,
            TrainedInIUCD: $("#TrainedInIUCD").val() || null,
            TrainedInFPLMIS: $("#TrainedInFPLMIS").val() || null,
            TrainedInCACS_MMA: parseInt($("#TrainedInCACS_MMA").val() || "0") || null
        };

        let token = $('input[name="__RequestVerificationToken"]').val();

        $.ajax({
            url: '/HR/SaveHrStatus',
            type: 'POST',
            contentType: 'application/json',
            headers: { 'RequestVerificationToken': token },
            data: JSON.stringify(modelhr),         
      
            success: function () {
            if (modelhr.HrId === 0) {
                Swal.fire('Success', 'HR saved successfully!', 'success');
            } else {
                Swal.fire('Success', 'HR updated successfully!', 'success');
            }
            $("#hrStatusModal").modal('hide');
            loadHrList(currentPage);
        },
            error: function () {
                Swal.fire('Error', 'Something went wrong!', 'error');
            }
        });
    });

    // Load HR List
    function loadHrList(page = 1) {
        currentPage = page;
        $.get('/HR/GetHrListPaged', { pageNumber: page, pageSize: pageSize }, function (res) {
            let rows = "";
            $.each(res.data, function (i, item) {
                rows += `<tr>
                            <td>${((page - 1) * pageSize) + i + 1}</td>
                            <td>${item.name}</td>
                            <td>${item.designationName ?? item.designationId}</td>
                            <td>${item.mobile}</td>
                            <td>${item.attendentVCAT == 1 ? 'Yes' : 'No'}</td>
                            <td>
                                   <button class="btn btn-sm btn-outline-primary editHr" data-id="${item.hrId}">
        <i class="bi bi-pencil"></i> 
    </button>
                            </td>
                         </tr>`;
            });
            $("#hrTableBody").html(rows);
            renderPagination(res.totalCount, page, pageSize);
        });
    }


    // Status Change
    function handleStatusChange() {
        let status = $("#Status").val();
        if (status == "No") { 
            $("#Name, #Mobile, #GenderId").prop("disabled", true);
            $("#trainingSection").hide();
            $("#btnSaveHr").hide();
        } else {
            $("#Name, #Mobile, #GenderId").prop("disabled", false);
            $("#trainingSection").show();
            $("#btnSaveHr").show();
        }
    }
    $(document).on("change", "#Status", handleStatusChange);

    // Clear modal
    function clearHrModal() {
        $("#hrStatusModal").find("input[type=text], input[type=hidden]").val('');
        $("#hrStatusModal").find("select").val('');
        $("#hrModalTitle").text("Add HR Profile");
        $("#btnSaveHr").text("Save");
        $("#trainingSection").show();
        $("#btnSaveHr").show();
    }</script>


