<div class="container py-2">
    <div class="card um-card">
        <div class="card-body">
            <div class="umcard-header">
                <div class="d-flex justify-content-between align-items-center">
                    <div>
                        <h3 class="mb-0">Users</h3>
                    </div>

                    <div class="um-toolbar">
                        <div class="d-flex um-search">
                            <input id="searchTerm" class="form-control" placeholder="Search by name or email" />
                            <button type="button" class="btn btn-sm  btn-outline-secondary ms-2" onclick="searchUser()">Search</button>
                        </div>


                        <a href="@Url.Action("Create", "User")" class="btn  btn-add btn-primary ms-3" style="z-index: 1000; position: relative;">
                            Add User
                        </a>
                    </div>
                </div>
            </div>
            <hr />

            <div class="row mb-3">
                <div class="col-md-2">
                    @* <label>State</label> *@
                    <select name="StateId" class="form-control" id="StateId">
                        <option value="">-- Select State --</option>
                        @foreach (var s in ViewBag.States)
                        {
                            <option value="@s.Id" @(ViewBag.StateId == s.Id ? "selected" : "")>@s.Name</option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                   @*  <label>District</label> *@
                    <select name="DistrictId" class="form-control" id="DistrictId">
                        <option value="">-- Select District --</option>
                    </select>
                </div>
                </div>

            @if (!Model?.Any() ?? true)
            {
                <div class="um-empty">
                    <p class="mb-1">No users found.</p>
                    <a class="btn btn-outline-primary" asp-action="Create" asp-controller="User">Add your first user</a>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table id="usersTable" class="table table-hover um-table align-middle">
                        <thead>
                            <tr>
                               <th style="width:1%;">#</th>
                               <th><i class="bi bi-person me-2"></i>Username</th>
                                <th><i class="bi bi-envelope me-2"></i>Email</th>
                                <th><i class="bi bi-briefcase me-2"></i>Role</th>
                                <th><i class="bi bi-check-circle me-2"></i>Active</th>
                                <th><i class="bi bi-pencil-square me-2"></i>Actions</th>

                            </tr>
                        </thead>
                        <tbody>
                        @foreach (var item in Model.Select((value, index) => (value, index)))
                        {
                            var user = item.value;
                            var idx = item.index + 1;
                            <tr>
                                <td>@idx</td>
                                <td>
                                    <div class="fw-semibold">@user.MobileNumber</div>
                                </td>
                                <td>@user.Email</td>
                                <td>
                                    @if (user.RoleName != null)
                                    {
                                        <span class="badge bg-info um-badge-role" title="@user.RoleName">@user.RoleName</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted small">—</span>
                                    }
                                </td>
                                <td class="text-center">
                                    @if (user.IsActive==1)
                                    {
                                        <span class="badge bg-success">Yes</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">No</span>
                                    }
                                </td>
                                    <td class="text-end um-action">
                                        <a class="btn btn-sm btn-outline-primary me-1"
                                           asp-controller="User"
                                           onclick="goToEdit(@user.UserId)"
                                           asp-route-id="@user.UserId"
                                           title="Edit">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <input type="hidden" asp-for="UserId" />
                                        <form asp-controller="User"
                                              asp-action="Delete"
                                              asp-route-id="@user.UserId"
                                              method="post"
                                              class="d-inline"
                                              onclick="deleteUser(@user.UserId)">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Delete">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>

                                        <!-- Update Password Button -->
                                        <a class="btn btn-sm btn-outline-warning ms-1"
                                           href="javascript:void(0);"
                                           onclick="openPasswordModal(@user.UserId)"
                                           title="Update Password">
                                           <i class="bi bi-key"></i>
                                        </a>

                                    </td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            }

           <nav>
    <ul class="pagination justify-content-end">

        <!-- Previous -->
        <li class="page-item @(ViewBag.CurrentPage <= 1 ? "disabled" : "")">
            <a class="page-link"
               href="@(ViewBag.CurrentPage <= 1 ? "#" : Url.Action("Index", new {
                   page = ViewBag.CurrentPage - 1,
                   pageSize = ViewBag.PageSize,
                   stateId = ViewBag.StateId,
                   districtId = ViewBag.DistrictId
               }))">
                Previous
            </a>
        </li>

        <!-- Page Numbers -->
        @for (int p = 1; p <= ViewBag.TotalPages; p++)
        {
            <li class="page-item @(p == ViewBag.CurrentPage ? "active" : "")">
                <a class="page-link"
                   href="@Url.Action("Index", new {
                       page = p,
                       pageSize = ViewBag.PageSize,
                       stateId = ViewBag.StateId,
                       districtId = ViewBag.DistrictId
                   })">
                    @p
                </a>
            </li>
        }

        <!-- Next -->
        <li class="page-item @(ViewBag.CurrentPage >= ViewBag.TotalPages ? "disabled" : "")">
            <a class="page-link"
               href="@(ViewBag.CurrentPage >= ViewBag.TotalPages ? "#" : Url.Action("Index", new {
                   page = ViewBag.CurrentPage + 1,
                   pageSize = ViewBag.PageSize,
                   stateId = ViewBag.StateId,
                   districtId = ViewBag.DistrictId
               }))">
                Next
            </a>
        </li>

    </ul>
</nav>
        </div>
    </div>
    <!-- Update Password Modal -->
<div class="modal fade" id="passwordModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Update Password</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">

                <input type="hidden" id="passwordUserId" />

               <div class="mb-3">
    <label>Old Password</label>
    <div class="input-group">
        <input type="password" id="oldPassword"
               class="form-control" />

        <span class="input-group-text"
              onclick="togglePassword('oldPassword', this)"
              style="cursor:pointer;">
            <i class="bi bi-eye"></i>
        </span>
    </div>
    <small id="oldPasswordError" class="text-danger"></small>
</div>

               <div class="mb-3">
    <label>New Password</label>
    <div class="input-group">
        <input type="password" id="newPassword"
               class="form-control"
               oninput="validateNewPassword()" />

        <span class="input-group-text"
              onclick="togglePassword('newPassword', this)"
              style="cursor:pointer;">
            <i class="bi bi-eye"></i>
        </span>
    </div>
    <small id="newPasswordError" class="text-danger"></small>
</div>

                <div class="mb-3">
    <label>Confirm Password</label>
    <div class="input-group">
        <input type="password" id="confirmPassword"
               class="form-control"
               oninput="validateConfirmPassword()" />

        <span class="input-group-text"
              onclick="togglePassword('confirmPassword', this)"
              style="cursor:pointer;">
            <i class="bi bi-eye"></i>
        </span>
    </div>
    <small id="confirmPasswordError" class="text-danger"></small>
</div>

            </div>

            <div class="modal-footer">
                <button class="btn-save" onclick="updatePassword()">Update</button>
            </div>
        </div>
    </div>
</div>
</div>
<script>
    function togglePassword(fieldId, element) {

    let input = document.getElementById(fieldId);
    let icon = element.querySelector("i");

    if (input.type === "password") {
        input.type = "text";
        icon.classList.remove("bi-eye");
        icon.classList.add("bi-eye-slash");
    }
    else {
        input.type = "password";
        icon.classList.remove("bi-eye-slash");
        icon.classList.add("bi-eye");
    }
}

    function goToEdit(id) {
        window.location.href = '/User/Edit/' + id;
    }


        function deleteUser(userId) {
        if (!confirm("Are you sure you want to delete this user?")) {
            return;
        }

        fetch('/User/Delete', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
                'RequestVerificationToken':
                    document.querySelector('input[name="__RequestVerificationToken"]').value
            },
            body: JSON.stringify(userId)
        })
        .then(res => res.json())
        .then(data => {
            if (data.success) {
                alert("User deleted successfully");
                window.location.reload();
            } else {
                alert(data.message || "Delete failed");
            }
        })
        .catch(err => {
            console.error(err);
            alert("Error occurred while deleting user");
        });
    }

            async function searchUser() {
        const term = document.getElementById("searchTerm").value;

        const response = await fetch(`/User/Search?q=${encodeURIComponent(term)}`);
        const html = await response.text();

        document.querySelector("#usersTable tbody").innerHTML = html;
    }

    // ---------------- CASCADING DROPDOWNS ----------------

            document.getElementById("StateId").addEventListener("change", function () {
                let stateId = this.value;
                resetDropdown("DistrictId", "-- Select District --");
                
             searchData();
                if (!stateId) return;

                fetch(`/User/GetDistricts?stateId=${stateId}`)
         .then(res => res.json())
         .then(data => {
             fillDropdown("DistrictId", data, "id", "name");
         });
      });

      function resetDropdown(id, placeholder) {
                let ddl = document.getElementById(id);
                ddl.innerHTML = `
               <option value="">${placeholder}</option>`;
            }

            function fillDropdown(id, data, valueField, textField) {
                let ddl = document.getElementById(id);
                data.forEach(x => {
         let opt = document.createElement("option");
         opt.value = x[valueField];
         opt.text = x[textField];
         ddl.appendChild(opt);
                });
            }

            document.getElementById("DistrictId").addEventListener("change", function () {
    searchData();
});

    function searchData() {

    var stateId = document.getElementById("StateId").value;
    var districtId = document.getElementById("DistrictId").value;

    var url = '/User/Index?page=1&pageSize=10'
        + '&stateId=' + stateId
        + '&districtId=' + districtId;

    window.location.href = url;
}

    document.addEventListener("DOMContentLoaded", async function () {

    var stateId = "@ViewBag.StateId";
    var districtId = "@ViewBag.DistrictId";

    if (stateId) {

        document.getElementById("StateId").value = stateId;

        let districts = await fetch(`/User/GetDistricts?stateId=${stateId}`)
            .then(res => res.json());

        fillDropdown("DistrictId", districts, "id", "name");

        if (districtId) {
                    document.getElementById("DistrictId").value = districtId;
                }
    }
    });

    function openPasswordModal(userId) {
    document.getElementById("passwordUserId").value = userId;

    // clear fields
    document.getElementById("oldPassword").value = "";
    document.getElementById("newPassword").value = "";
    document.getElementById("confirmPassword").value = "";

    var modal = new bootstrap.Modal(document.getElementById('passwordModal'));
    modal.show();
}

function validateNewPassword() {

    let password = document.getElementById("newPassword").value;
    let error = document.getElementById("newPasswordError");

    let regex = /^(?=.*[A-Za-z])(?=.*\d).{6,}$/;

    if (password === "") {
        error.innerText = "Password is required";
    }
    else if (!regex.test(password)) {
        error.innerText = "Minimum 6 characters, include letters & numbers";
    }
    else {
        error.innerText = "";
    }

    validateConfirmPassword();
}

function validateConfirmPassword() {

    let password = document.getElementById("newPassword").value;
    let confirmPassword = document.getElementById("confirmPassword").value;
    let error = document.getElementById("confirmPasswordError");

    if (confirmPassword === "") {
        error.innerText = "";
        return;
    }

    if (confirmPassword !== password) {
        error.innerText = "Passwords do not match";
    }
    else {
        error.innerText = "";
    }
}

function updatePassword() {

    let userId = document.getElementById("passwordUserId").value;
    let oldPassword = document.getElementById("oldPassword").value;
    let newPassword = document.getElementById("newPassword").value;

    fetch('/User/UpdatePassword', {
        method: 'POST',
        headers: {
            'Content-Type': 'application/json'
        },
        body: JSON.stringify({
            UserId: userId,
            OldPassword: oldPassword,
            NewPassword: newPassword
        })
    })
    .then(res => res.json())
    .then(data => {

        if (data.success) {
            alert("Password updated successfully");
            location.reload();
        }
        else {
            document.getElementById("oldPasswordError").innerText = data.message;
        }

    });
}
</script>
