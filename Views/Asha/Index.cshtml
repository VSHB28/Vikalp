@using Vikalp.Models.DTO
@model List<AshaDto>

@{
    ViewData["Title"] = "Asha List";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>

    .um-card {
        border-radius: 0.5rem;
        box-shadow: 0 6px 18px rgba(12, 38, 63, 0.08);
    }

    .um-toolbar {
        gap: .5rem;
        display: flex;
        align-items: center;
        flex-wrap: wrap;
    }

    .um-table thead th {
        color: #fff;
        border: 1px dotted;
        background: var(--ipas-sidebar);
    }

    .um-table tbody tr:hover {
        background: rgba(13,110,253,0.03);
    }

    .um-action .btn {
        min-width: 44px;
        margin-left: 0.2rem;
    }

    .btn-add {
        background-color: #3F0C11;
        color: white;
    }

</style>

<div class="container py-2">
    <div class="card um-card">
        <div class="card-body">

            <div class="umcard-header">
                <div class="d-flex justify-content-between align-items-center">

                    <div>
                        <h3 class="mb-0">Asha List</h3>
                    </div>

                    <div class="um-toolbar">
                        <a href="/Asha/Create" class="btn btn-add btn-primary ms-3">
                            Add Asha
                        </a>
                    </div>

                </div>
            </div>

            <hr />


            <div class="row g-2 mb-3">
                <div class="col-md-3">
                    <select id="stateDropdown" class="form-control form-control-sm">
                        <option value="">Select State</option>
                        @foreach (var s in ViewBag.States)
                        {
                            <option value="@s.Id">@s.Name</option>
                        }
                    </select>
                </div>

                <div class="col-md-3">
                    <select id="districtDropdown" class="form-control form-control-sm">
                        <option value="">Select District</option>
                    </select>
                </div>

                <div class="col-md-3">
                    <select id="blockDropdown" class="form-control form-control-sm">
                        <option value="">Select Block</option>
                    </select>
                </div>

                <div class="col-md-3">
                    <select id="facilityDropdown" class="form-control form-control-sm">
                        <option value="">Select Facility</option>
                    </select>
                </div>

                <div class="col-md-3">
                    <select id="subCentreDropdown" class="form-control form-control-sm">
                        <option value="">Select Sub Centre</option>
                    </select>
                </div>
            </div>

            <div class="table-responsive">
                <table class="table table-hover um-table align-middle">

                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Name</th>
                            <th>Mobile</th>
                            <th >Active</th>
                            <th >VCAT Attended</th>
                            <th>Actions</th>
                        </tr>
                    </thead>

                    <tbody>

                        @{
                            int i = 1;
                        }

                        @foreach (var item in Model)
                        {
                            <tr>

                                <td>@i</td>

                                <td class="fw-semibold">@item.AshaName</td>

                                <td>@item.AshaMobile</td>

                                <td class="text-center">
                                    <span class="badge @(item.IsActive ? "bg-success" : "bg-secondary")">
                                        @(item.IsActive ? "Active" : "Inactive")
                                    </span>
                                </td>

                                <td class="text-center">
                                    <span class="badge @(item.AttendedVCAT ? "bg-info" : "bg-secondary")">
                                        @(item.AttendedVCAT ? "Yes" : "No")
                                    </span>
                                </td>

                                <td class="text-end um-action">

                           
                                    <a href="/Asha/Edit/@item.AshaId" class="btn btn-sm btn-outline-primary" title="Edit">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                
                                    <button type="button"
                                            onclick="deleteAsha(@item.AshaId)"
                                            class="btn btn-sm btn-outline-danger"
                                            title="Delete">
                                        <i class="bi bi-trash"></i>
                                    </button>

                                </td>

                            </tr>

                            i++;
                        }

                    </tbody>

                </table>

                @{
                    int page = ViewBag.PageNumber ?? 1;
                    int pageSize = ViewBag.PageSize ?? 10;
                    int totalCount = ViewBag.TotalCount ?? Model.Count;

                    int totalPages = (int)Math.Ceiling((double)totalCount / pageSize);
                }

                <ul class="pagination justify-content-end mt-3">

                    <li class="page-item @(page <= 1 ? "disabled" : "")">
                        <a class="page-link" href="/Asha/Index?page=@(page - 1)&pageSize=@pageSize">
                            Previous
                        </a>
                    </li>

                    @for (int p = 1; p <= totalPages; p++)
                    {
                        <li class="page-item @(p == page ? "active" : "")">
                            <a class="page-link" href="/Asha/Index?page=@p&pageSize=@pageSize">
                                @p
                            </a>
                        </li>
                    }

                    <li class="page-item @(page >= totalPages ? "disabled" : "")">
                        <a class="page-link" href="/Asha/Index?page=@(page + 1)&pageSize=@pageSize">
                            Next
                        </a>
                    </li>

                </ul>
            </div>

        </div>
    </div>
</div>
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>


<script>
    $(document).ready(function () {

     
        $('#stateDropdown').change(function () {

        let stateId = $(this).val();

        resetBelow('state');

        if (!stateId) {
            filterAshaTable();
            return;
        }

        $.getJSON('/Asha/GetDistricts',
            { stateId: stateId },
            function (data) {

                $.each(data, function (i, d) {
                    $('#districtDropdown').append(`<option value="${d.id}">${d.name}</option>`);
                });

                filterAshaTable();   
            });
    });

    
       $('#districtDropdown').change(function () {

        let districtId = $(this).val();

        resetBelow('district');

        if (!districtId) {
            filterAshaTable();
            return;
        }

        $.getJSON('/Asha/GetBlocks',
            { districtId: districtId },
            function (data) {

                $.each(data, function (i, b) {
                    $('#blockDropdown').append(`<option value="${b.id}">${b.name}</option>`);
                });

                filterAshaTable(); 
            });
    });

    $('#blockDropdown').change(function () {

        let blockId = $(this).val();

        resetBelow('block');

        if (!blockId) {
            filterAshaTable();
            return;
        }

        $.getJSON('/Asha/GetFacilities',
            { blockId: blockId },
            function (data) {

                $.each(data, function (i, f) {
                    $('#facilityDropdown').append(`<option value="${f.id}">${f.name}</option>`);
                });

                filterAshaTable();   
            });
    });

    
            $('#facilityDropdown').change(function () {

        let facilityId = $(this).val();

        $('#subCentreDropdown').html('<option value="">Select Sub Centre</option>');

        if (!facilityId) {
            filterAshaTable();
            return;
        }

        $.getJSON('/Asha/GetSubCentres',
            { facilityId: facilityId },
            function (data) {

                $.each(data, function (i, s) {
                    $('#subCentreDropdown').append(`<option value="${s.id}">${s.name}</option>`);
                });

                filterAshaTable();
            });
    });

        function resetBelow(level) {

            if (level === 'state') {

                $('#districtDropdown').html('<option value="">Select District</option>');
                $('#blockDropdown').html('<option value="">Select Block</option>');
                $('#facilityDropdown').html('<option value="">Select Facility</option>');
            }

            if (level === 'district') {

                $('#blockDropdown').html('<option value="">Select Block</option>');
                $('#facilityDropdown').html('<option value="">Select Facility</option>');
            }

            if (level === 'block') {

                $('#facilityDropdown').html('<option value="">Select Facility</option>');
            }
        }

  function filterAshaTable() {

        let stateId = $('#stateDropdown').val() || null;
        let districtId = $('#districtDropdown').val() || null;
        let blockId = $('#blockDropdown').val() || null;
        let facilityId = $('#facilityDropdown').val() || null;
        let subCentreId = $('#subCentreDropdown').val() || null;

        $.ajax({
            url: '/Asha/GetByFilter',
            type: 'GET',
            data: {
                stateId: stateId,
                districtId: districtId,
                blockId: blockId,
                facilityId: facilityId,
                subCentreId: subCentreId
            },
            success: function (data) {

                let tbody = $('.um-table tbody');
                tbody.empty();

                if (data.length > 0) {

                    $.each(data, function (i, item) {

                        let row = `<tr>
                            <td>${i + 1}</td>
                            <td class="fw-semibold">${item.ashaName}</td>
                            <td>${item.ashaMobile}</td>
                            <td class="text-center">
                                <span class="badge ${item.isActive ? 'bg-success':'bg-secondary'}">
                                    ${item.isActive ? 'Active':'Inactive'}
                                </span>
                            </td>
                            <td class="text-center">
                                <span class="badge ${item.attendedVCAT ? 'bg-info':'bg-secondary'}">
                                    ${item.attendedVCAT ? 'Yes':'No'}
                                </span>
                            </td>
                            <td class="text-end">
                                <a href="/Asha/Edit/${item.ashaId}" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-pencil"></i>
                                </a>
                            </td>
                        </tr>`;

                        tbody.append(row);
                    });

                } else {

                    tbody.append('<tr><td colspan="6" class="text-center">No record found</td></tr>');

                }
            }
        });
    }
        $('#subCentreDropdown').change(function () {
        filterAshaTable();
    });

    function deleteAsha(id) {

        Swal.fire({
            title: 'Are you sure?',
            text: 'This Asha will be deleted',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonText: 'Yes, delete it!'
        }).then((result) => {

            if (result.isConfirmed) {

                $.ajax({
                    url: '/Asha/DeleteConfirmed',
                    type: 'POST',
                    data: {
                        id: id,
                        __RequestVerificationToken: $('input[name="__RequestVerificationToken"]').val()
                    },
                    success: function (res) {

                        if (res.success) {
                            Swal.fire('Deleted!', 'Asha deleted successfully.', 'success')
                                .then(() => {
                                    window.location.href = "/Asha/Index";
                                });
                        }

                    },
                    error: function () {
                        Swal.fire('Error!', 'Could not delete Asha.', 'error');
                    }
                });

            }

        });
    }

    });   
</script>

