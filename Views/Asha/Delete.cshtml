@model Vikalp.Models.DTO.AshaDto

@{
    ViewData["Title"] = "Delete Asha";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container py-4">

    <div class="card shadow-sm">
        <div class="card-body">

            <h4 class="text-danger mb-3">Delete Asha</h4>

            <div class="alert alert-warning">
                Are you sure you want to delete this Asha?
            </div>

            <dl class="row">

                <dt class="col-sm-3">Name</dt>
                <dd class="col-sm-9">@Model.AshaName</dd>

                <dt class="col-sm-3">Mobile</dt>
                <dd class="col-sm-9">@Model.AshaMobile</dd>

                <dt class="col-sm-3">Active</dt>
                <dd class="col-sm-9">
                    @(Model.IsActive ? "Yes" : "No")
                </dd>

                <dt class="col-sm-3">VCAT Attended</dt>
                <dd class="col-sm-9">
                    @(Model.AttendedVCAT ? "Yes" : "No")
                </dd>

            </dl>

            <form id="deleteForm">
                @Html.AntiForgeryToken()

                <input type="hidden" id="ashaId" value="@Model.AshaId" />

                <button type="button"
                        onclick="deleteAsha(@Model.AshaId)"
                        class="btn btn-danger">
                    Yes, Delete
                </button>

                <a href="/Asha/Index" class="btn btn-secondary ms-2">
                    Cancel
                </a>

            </form>

        </div>
    </div>

</div>


